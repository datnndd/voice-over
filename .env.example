# Voice Over runtime configuration. Copy to `.env` and fill only providers you use.

# Processing outputs. Defaults to C:\Users\ddat2\Downloads when unset.
# VOICE_OVER_OUTPUTS=C:\Users\ddat2\Downloads
VOICE_OVER_UPLOADS=C:\Users\ddat2\Downloads\voice-over\data\uploads

# Google Drive output upload. Share the target Drive folder with the service account email.
VOICE_OVER_GOOGLE_DRIVE_ENABLED=0
VOICE_OVER_GOOGLE_DRIVE_FOLDER_ID=
VOICE_OVER_GOOGLE_DRIVE_CREDENTIALS_FILE=
VOICE_OVER_GOOGLE_DRIVE_CREDENTIALS_JSON=

# STT providers
VOICE_OVER_DEEPGRAM_APIKEY=
VOICE_OVER_QWENMT_KEY=
VOICE_OVER_QWEN3_ASR_MODEL=qwen3-asr-flash

# TTS providers
VOICE_OVER_AZURE_SPEECH_KEY=
VOICE_OVER_AZURE_SPEECH_REGION=
VOICE_OVER_OMNIVOICE_URL=http://127.0.0.1:7860
VOICE_OVER_DEFAULT_VOICE_ROLE=HoaiMy(Female)
VOICE_OVER_VIENEU_MODE=standard
VOICE_OVER_VIENEU_API_BASE=
VOICE_OVER_VIENEU_MODEL_NAME=
VOICE_OVER_VIENEU_VOICE_ROLES=Ngoc Lan,Xuan Vinh,Ngoc Linh

# LLM translators
VOICE_OVER_CHATGPT_KEY=
VOICE_OVER_CHATGPT_API=https://api.openai.com/v1
VOICE_OVER_CHATGPT_MODEL=gpt-4o-mini
VOICE_OVER_DEEPSEEK_KEY=
VOICE_OVER_DEEPSEEK_API=https://api.deepseek.com/v1
VOICE_OVER_DEEPSEEK_MODEL=deepseek-chat

# Optional provider visibility examples
# VOICE_OVER_PROVIDER_ALLOW=stt:10,tts:28,translator:3
# VOICE_OVER_PROVIDER_DENY=local
